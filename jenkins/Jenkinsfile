
pipeline {
    agent any

    stages {
        stage('Environment Check') {
            steps {
                echo 'Checking Java version...'
                sh '''
                    echo "JAVA_HOME=$JAVA_HOME"
                    java -version
                '''
            }
        }

        stage('Hello World') {
            steps {
                echo 'Hello World from Jenkins Pipeline!'
            }
        }
    }

    post {
        success {
            echo '✅ Pipeline executed successfully'
        }
        failure {
            echo '❌ Pipeline failed'
        }
    }
}
