
pipeline {
  agent any

  options {
    timestamps()
  }

  triggers {
    // optional: every push ke bajaye poll SCM karna ho to uncomment
    // pollSCM('@hourly')
  }

  stages {
    stage('Check Java & Git') {
      steps {
        sh 'java -version || true'
        sh 'git --version'
      }
    }

    stage('Build') {
      steps {
        sh './mvnw -B -DskipTests clean package'
      }
    }

    stage('Test') {
      steps {
        sh './mvnw test'
      }
    }

    stage('Package Info') {
      steps {
        sh 'ls -lah target || true'
      }
    }
  }

  post {
    success {
      archiveArtifacts artifacts: 'target/**/*.jar', fingerprint: true
      junit allowEmptyResults: true, testResults: 'target/surefire-reports/*.xml'
    }
    always {
      echo "Build finished: ${currentBuild.currentResult}"
    }
  }
}
