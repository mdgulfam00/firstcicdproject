
pipeline {
    agent any

    tools {
        jdk 'JDK-21'       // Must match Jenkins Global Tool Configuration
        maven 'Maven-3.6.3'
    }

    environment {
        APP_NAME = "demo-java-app"
    }

    stages {

        stage('Checkout Code') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/mdgulfam00/firstcicdproject.git'
            }
        }

        stage('Java Version') {
            steps {
                sh '''
                    echo "JAVA_HOME=$JAVA_HOME"
                    java -version
                    mvn -version
                '''
            }
        }

        stage('Build') {
            steps {
                sh 'mvn -f backend/pom.xml clean package -DskipTests'
            }
        }

        // stage('Test') {
        //     steps {
        //         sh 'mvn test'
        //     }
        // }
    }

    post {
        success {
            echo "✅ Build successful for ${APP_NAME}"
            // archiveArtifacts artifacts: 'target/*.jar', fingerprint: true
        }

        failure {
            echo "❌ Build failed for ${APP_NAME}"
        }

        always {
            echo 'Pipeline execution completed'
        }
    }
}
